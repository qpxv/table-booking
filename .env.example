# --- Datenbank (Neon Postgres) -------------------------------------------
# Wird zur Laufzeit von der App genutzt (pooled/PgBouncer-Connection-String aus Neon).
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"
# Wird von Prisma Migrate/CLI genutzt (direkte/unpooled Connection-String aus Neon,
# nötig für Migrationen). In Neon: "Direct connection" statt "Pooled connection".
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# --- Better Auth -----------------------------------------------------------
# Generieren mit: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-me-with-openssl-rand--base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# --- App ---------------------------------------------------------------
NEXT_PUBLIC_APP_URL="http://localhost:3000"
